<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <title>Document</title>
</head>
<body>

    <!-- Image Centered -->
    <div class="text-center my-4">
        <img src="./img/index.jpeg" alt="" style="width: 70%;">
    </div>

    <!-- Berita Terkini Section -->
    <div class="container my-5">
        <h4>Berita Terkini</h4>
        <% berita.forEach(function(berita) { %>
            <h2><%= berita.judul %></h2>
            <p><%= berita.isi %></p>
        <% }) %>
    </div>

    <!-- Cards Section for Berita -->
    <div class="container">
        <div class="row">
            <!-- Card 1 for Berita 1 -->
            <div class="col-md-6">
                <div class="card">
                    <img src="https://via.placeholder.com/400x250" class="card-img-top" alt="Image 1">
                    <div class="card-body">
                        <h5 class="card-title"><%= berita[0].judul %></h5>
                        <p class="card-text"><%= berita[0].isi.substring(0, 100) %>...</p>
                        <a href="#" class="btn btn-primary">Baca Selengkapnya</a>
                    </div>
                </div>
            </div>

            <!-- Card 2 for Berita 2 -->
            <div class="col-md-6">
                <div class="card">
                    <img src="https://via.placeholder.com/400x250" class="card-img-top" alt="Image 2">
                    <div class="card-body">
                        <h5 class="card-title"><%= berita[1].judul %></h5>
                        <p class="card-text"><%= berita[1].isi.substring(0, 100) %>...</p>
                        <a href="#" class="btn btn-primary">Baca Selengkapnya</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-ho+j7jyWK8fNQe+A12WNL0XR0a7swKBlbc61FjfEFvK9m8jGSKVqq6L+fj/Ek7F3" crossorigin="anonymous"></script>
</body>
</html>
